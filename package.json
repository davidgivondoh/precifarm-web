{
  "name": "precifarm-web",
  "version": "0.1.0",
  "private": true,
  "description": "Marketing website for Precifarm — distributed solar energy in Kenya.",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.18.2",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "export:serve": "serve out -l 4173",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium firefox webkit",
    "lhci": "lhci autorun",
    "check:links": "node scripts/check-links.mjs",
    "postbuild": "next-sitemap --config next-sitemap.config.mjs && node scripts/strip-style-guide.mjs"
  },
  "dependencies": {
    "@formspree/react": "3.0.0",
    "clsx": "2.1.1",
    "gray-matter": "4.0.3",
    "lucide-react": "0.469.0",
    "next": "16.2.4",
    "next-mdx-remote": "5.0.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.1",
    "@eslint/eslintrc": "3.2.0",
    "@lhci/cli": "0.14.0",
    "@playwright/test": "1.49.1",
    "@resvg/resvg-js": "2.6.2",
    "@svgr/webpack": "8.1.0",
    "@tailwindcss/postcss": "4.2.4",
    "@types/node": "22.10.2",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "@typescript-eslint/eslint-plugin": "8.18.2",
    "@typescript-eslint/parser": "8.18.2",
    "@vitejs/plugin-react": "4.3.4",
    "eslint": "9.17.0",
    "eslint-config-next": "16.2.4",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "next-sitemap": "4.2.3",
    "prettier": "3.4.2",
    "prettier-plugin-tailwindcss": "0.6.9",
    "satori": "0.26.0",
    "serve": "14.2.4",
    "tailwindcss": "4.2.4",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
